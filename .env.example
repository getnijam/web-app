# Local dev (API running on localhost:8787)
VITE_API_URL=http://localhost:8787
NIJAM_SPEC_URL=http://localhost:8787/openapi.json

# Production
# VITE_API_URL=https://api.nijam.dev
# NIJAM_SPEC_URL=https://api.nijam.dev/openapi.json

# Error monitoring + session replay + tracing — Better Stack (via the Sentry SDK).
# Set VITE_SENTRY_DSN to the web app's Better Stack source (required for monitoring; it's
# a public client key, inlined into the bundle at build). Monitoring runs on prod builds
# only (dev off by default) — set it on Vercel for prod.
VITE_SENTRY_DSN=https://<key>@<host>.betterstackdata.com/<source-id>
#
# Product analytics (user-action tracking) — Better Stack. Set the source token (the `t=`
# value from the Better Stack snippet; a public client key, inlined into the bundle at build).
# Loaded on prod builds only (dev off by default); `environment` is derived from the build mode.
VITE_BETTERSTACK_ANALYTICS_TOKEN=<better-stack-analytics-source-token>
#
# Test monitoring + analytics in local dev (sends real events to Better Stack) — off by default:
# VITE_MONITORING_DEV=true
#
# Source-map upload to Better Stack (build-only; set as encrypted env vars on Vercel,
# never commit the token). Values from Errors → Applications → [app] → Advanced settings:
#   SENTRY_URL=https://<region>-sourcemaps.betterstackdata.com
#   SENTRY_ORG=<better-stack-team-id>
#   SENTRY_PROJECT=<better-stack-app-id>
#   SENTRY_AUTH_TOKEN=<better-stack-telemetry-api-token>   # secret

# ── Playwright E2E (auto-loaded by playwright.config.ts) ──────────────────────
# Login — required for the lifecycle spec to actually run (otherwise it skips).
# NIJAM_E2E_EMAIL=
# NIJAM_E2E_PASSWORD=
#
# Push runs to Nijam — set BOTH to upload via @nijam/pw-reporter.
# Comment out (or empty) NIJAM_API_KEY when you DON'T want to push.
# NIJAM_API_KEY=
# NIJAM_PROJECT_ID=
# NIJAM_API_URL=https://api.nijam.dev
#
# Target app under test (optional; defaults to https://www.nijam.dev).
# NIJAM_E2E_BASE_URL=http://localhost:5173
