# Local dev (API running on localhost:8787)
VITE_API_URL=http://localhost:8787
NIJAM_SPEC_URL=http://localhost:8787/openapi.json

# Production
# VITE_API_URL=https://api.nijam.dev
# NIJAM_SPEC_URL=https://api.nijam.dev/openapi.json

# Error monitoring — Sentry. Inlined at build; unset → SDK disabled (dev is always off).
# VITE_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
#
# Source-map upload (build-only; set as encrypted env vars on Vercel, never commit):
#   SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT
